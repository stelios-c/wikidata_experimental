    "import pandas as pd"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "967649e4-5836-4bd4-bf51-219c22a5b093",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "\u001b[31mSignature:\u001b[39m\n",
       "pd.read_html(\n",
       "    io: \u001b[33m'FilePath | ReadBuffer[str]'\u001b[39m,\n",
       "    *,\n",
       "    match: \u001b[33m'str | Pattern'\u001b[39m = \u001b[33m'.+'\u001b[39m,\n",
       "    flavor: \u001b[33m'HTMLFlavors | Sequence[HTMLFlavors] | None'\u001b[39m = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       "    header: \u001b[33m'int | Sequence[int] | None'\u001b[39m = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       "    index_col: \u001b[33m'int | Sequence[int] | None'\u001b[39m = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       "    skiprows: \u001b[33m'int | Sequence[int] | slice | None'\u001b[39m = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       "    attrs: \u001b[33m'dict[str, str] | None'\u001b[39m = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       "    parse_dates: \u001b[33m'bool'\u001b[39m = \u001b[38;5;28;01mFalse\u001b[39;00m,\n",
       "    thousands: \u001b[33m'str | None'\u001b[39m = \u001b[33m','\u001b[39m,\n",
       "    encoding: \u001b[33m'str | None'\u001b[39m = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       "    decimal: \u001b[33m'str'\u001b[39m = \u001b[33m'.'\u001b[39m,\n",
       "    converters: \u001b[33m'dict | None'\u001b[39m = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       "    na_values: \u001b[33m'Iterable[object] | None'\u001b[39m = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       "    keep_default_na: \u001b[33m'bool'\u001b[39m = \u001b[38;5;28;01mTrue\u001b[39;00m,\n",
       "    displayed_only: \u001b[33m'bool'\u001b[39m = \u001b[38;5;28;01mTrue\u001b[39;00m,\n",
       "    extract_links: \u001b[33m\"Literal['header', 'footer', 'body', 'all'] | None\"\u001b[39m = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       "    dtype_backend: \u001b[33m'DtypeBackend | lib.NoDefault'\u001b[39m = <no_default>,\n",
       "    storage_options: \u001b[33m'StorageOptions'\u001b[39m = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       ") -> \u001b[33m'list[DataFrame]'\u001b[39m\n",
       "\u001b[31mSource:\u001b[39m   \n",
       "@set_module(\u001b[33m\"pandas\"\u001b[39m)\n",
       "\u001b[38;5;28;01mdef\u001b[39;00m read_html(\n",
       "    io: FilePath | ReadBuffer[str],\n",
       "    *,\n",
       "    match: str | Pattern = \u001b[33m\".+\"\u001b[39m,\n",
       "    flavor: HTMLFlavors | Sequence[HTMLFlavors] | \u001b[38;5;28;01mNone\u001b[39;00m = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       "    header: int | Sequence[int] | \u001b[38;5;28;01mNone\u001b[39;00m = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       "    index_col: int | Sequence[int] | \u001b[38;5;28;01mNone\u001b[39;00m = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       "    skiprows: int | Sequence[int] | slice | \u001b[38;5;28;01mNone\u001b[39;00m = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       "    attrs: dict[str, str] | \u001b[38;5;28;01mNone\u001b[39;00m = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       "    parse_dates: bool = \u001b[38;5;28;01mFalse\u001b[39;00m,\n",
       "    thousands: str | \u001b[38;5;28;01mNone\u001b[39;00m = \u001b[33m\",\"\u001b[39m,\n",
       "    encoding: str | \u001b[38;5;28;01mNone\u001b[39;00m = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       "    decimal: str = \u001b[33m\".\"\u001b[39m,\n",
       "    converters: dict | \u001b[38;5;28;01mNone\u001b[39;00m = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       "    na_values: Iterable[object] | \u001b[38;5;28;01mNone\u001b[39;00m = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       "    keep_default_na: bool = \u001b[38;5;28;01mTrue\u001b[39;00m,\n",
       "    displayed_only: bool = \u001b[38;5;28;01mTrue\u001b[39;00m,\n",
       "    extract_links: Literal[\u001b[33m\"header\"\u001b[39m, \u001b[33m\"footer\"\u001b[39m, \u001b[33m\"body\"\u001b[39m, \u001b[33m\"all\"\u001b[39m] | \u001b[38;5;28;01mNone\u001b[39;00m = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       "    dtype_backend: DtypeBackend | lib.NoDefault = lib.no_default,\n",
       "    storage_options: StorageOptions = \u001b[38;5;28;01mNone\u001b[39;00m,\n",
       ") -> list[DataFrame]:\n",
       "    \u001b[33mr\"\"\"\u001b[39m\n",
       "\u001b[33m    Read HTML tables into a ``list`` of ``DataFrame`` objects.\u001b[39m\n",
       "\n",
       "\u001b[33m    Parameters\u001b[39m\n",
       "\u001b[33m    ----------\u001b[39m\n",
       "\u001b[33m    io : str, path object, or file-like object\u001b[39m\n",
       "\u001b[33m        String path, path object (implementing ``os.PathLike[str]``), or file-like\u001b[39m\n",
       "\u001b[33m        object implementing a string ``read()`` function.\u001b[39m\n",
       "\u001b[33m        The string can represent a URL. Note that\u001b[39m\n",
       "\u001b[33m        lxml only accepts the http, ftp and file url protocols. If you have a\u001b[39m\n",
       "\u001b[33m        URL that starts with ``'https'`` you might try removing the ``'s'``.\u001b[39m\n",
       "\n",
       "\u001b[33m    match : str or compiled regular expression, optional\u001b[39m\n",
       "\u001b[33m        The set of tables containing text matching this regex or string will be\u001b[39m\n",
       "\u001b[33m        returned. Unless the HTML is extremely simple you will probably need to\u001b[39m\n",
       "\u001b[33m        pass a non-empty string here. Defaults to '.+' (match any non-empty\u001b[39m\n",
       "\u001b[33m        string). The default value will return all tables contained on a page.\u001b[39m\n",
       "\u001b[33m        This value is converted to a regular expression so that there is\u001b[39m\n",
       "\u001b[33m        consistent behavior between Beautiful Soup and lxml.\u001b[39m\n",
       "\n",
       "\u001b[33m    flavor : {\"lxml\", \"html5lib\", \"bs4\"} or list-like, optional\u001b[39m\n",
       "\u001b[33m        The parsing engine (or list of parsing engines) to use. 'bs4' and\u001b[39m\n",
       "\u001b[33m        'html5lib' are synonymous with each other, they are both there for\u001b[39m\n",
       "\u001b[33m        backwards compatibility. The default of ``None`` tries to use ``lxml``\u001b[39m\n",
       "\u001b[33m        to parse and if that fails it falls back on ``bs4`` + ``html5lib``.\u001b[39m\n",
       "\n",
       "\u001b[33m    header : int or list-like, optional\u001b[39m\n",
       "\u001b[33m        The row (or list of rows for a :class:`~pandas.MultiIndex`) to use to\u001b[39m\n",
       "\u001b[33m        make the columns headers.\u001b[39m\n",
       "\n",
       "\u001b[33m    index_col : int or list-like, optional\u001b[39m\n",
       "\u001b[33m        The column (or list of columns) to use to create the index.\u001b[39m\n",
       "\n",
       "\u001b[33m    skiprows : int, list-like or slice, optional\u001b[39m\n",
       "\u001b[33m        Number of rows to skip after parsing the column integer. 0-based. If a\u001b[39m\n",
       "\u001b[33m        sequence of integers or a slice is given, will skip the rows indexed by\u001b[39m\n",
       "\u001b[33m        that sequence.  Note that a single element sequence means 'skip the nth\u001b[39m\n",
       "\u001b[33m        row' whereas an integer means 'skip n rows'.\u001b[39m\n",
       "\n",
       "\u001b[33m    attrs : dict, optional\u001b[39m\n",
       "\u001b[33m        This is a dictionary of attributes that you can pass to use to identify\u001b[39m\n",
       "\u001b[33m        the table in the HTML. These are not checked for validity before being\u001b[39m\n",
       "\u001b[33m        passed to lxml or Beautiful Soup. However, these attributes must be\u001b[39m\n",
       "\u001b[33m        valid HTML table attributes to work correctly. For example, ::\u001b[39m\n",
       "\n",
       "\u001b[33m            attrs = {\"id\": \"table\"}\u001b[39m\n",
       "\n",
       "\u001b[33m        is a valid attribute dictionary because the 'id' HTML tag attribute is\u001b[39m\n",
       "\u001b[33m        a valid HTML attribute for *any* HTML tag as per `this document\u001b[39m\n",
       "\u001b[33m        <https://html.spec.whatwg.org/multipage/dom.html#global-attributes>`__. ::\u001b[39m\n",
       "\n",
       "\u001b[33m            attrs = {\"asdf\": \"table\"}\u001b[39m\n",
       "\n",
       "\u001b[33m        is *not* a valid attribute dictionary because 'asdf' is not a valid\u001b[39m\n",
       "\u001b[33m        HTML attribute even if it is a valid XML attribute.  Valid HTML 4.01\u001b[39m\n",
       "\u001b[33m        table attributes can be found `here\u001b[39m\n",
       "\u001b[33m        <http://www.w3.org/TR/REC-html40/struct/tables.html#h-11.2>`__. A\u001b[39m\n",
       "\u001b[33m        working draft of the HTML 5 spec can be found `here\u001b[39m\n",
       "\u001b[33m        <https://html.spec.whatwg.org/multipage/tables.html>`__. It contains the\u001b[39m\n",
       "\u001b[33m        latest information on table attributes for the modern web.\u001b[39m\n",
       "\n",
       "\u001b[33m    parse_dates : bool, optional\u001b[39m\n",
       "\u001b[33m        See :func:`~read_csv` for more details.\u001b[39m\n",
       "\n",
       "\u001b[33m    thousands : str, optional\u001b[39m\n",
       "\u001b[33m        Separator to use to parse thousands. Defaults to ``','``.\u001b[39m\n",
       "\n",
       "\u001b[33m    encoding : str, optional\u001b[39m\n",
       "\u001b[33m        The encoding used to decode the web page. Defaults to ``None``.``None``\u001b[39m\n",
       "\u001b[33m        preserves the previous encoding behavior, which depends on the\u001b[39m\n",
       "\u001b[33m        underlying parser library (e.g., the parser library will try to use\u001b[39m\n",
       "\u001b[33m        the encoding provided by the document).\u001b[39m\n",
       "\n",
       "\u001b[33m    decimal : str, default '.'\u001b[39m\n",
       "\u001b[33m        Character to recognize as decimal point (e.g. use ',' for European\u001b[39m\n",
       "\u001b[33m        data).\u001b[39m\n",
       "\n",
       "\u001b[33m    converters : dict, default None\u001b[39m\n",
       "\u001b[33m        Dict of functions for converting values in certain columns. Keys can\u001b[39m\n",
       "\u001b[33m        either be integers or column labels, values are functions that take one\u001b[39m\n",
       "\u001b[33m        input argument, the cell (not column) content, and return the\u001b[39m\n",
       "\u001b[33m        transformed content.\u001b[39m\n",
       "\n",
       "\u001b[33m    na_values : iterable, default None\u001b[39m\n",
       "\u001b[33m        Custom NA values.\u001b[39m\n",
       "\n",
       "\u001b[33m    keep_default_na : bool, default True\u001b[39m\n",
       "\u001b[33m        If na_values are specified and keep_default_na is False the default NaN\u001b[39m\n",
       "\u001b[33m        values are overridden, otherwise they're appended to.\u001b[39m\n",
       "\n",
       "\u001b[33m    displayed_only : bool, default True\u001b[39m\n",
       "\u001b[33m        Whether elements with \"display: none\" should be parsed.\u001b[39m\n",
       "\n",
       "\u001b[33m    extract_links : {None, \"all\", \"header\", \"body\", \"footer\"}\u001b[39m\n",
       "\u001b[33m        Table elements in the specified section(s) with <a> tags will have their\u001b[39m\n",
       "\u001b[33m        href extracted.\u001b[39m\n",
       "\n",
       "\u001b[33m    dtype_backend : {'numpy_nullable', 'pyarrow'}\u001b[39m\n",
       "\u001b[33m        Back-end data type applied to the resultant :class:`DataFrame`\u001b[39m\n",
       "\u001b[33m        (still experimental). If not specified, the default behavior\u001b[39m\n",
       "\u001b[33m        is to not use nullable data types. If specified, the behavior\u001b[39m\n",
       "\u001b[33m        is as follows:\u001b[39m\n",
       "\n",
       "\u001b[33m        * ``\"numpy_nullable\"``: returns nullable-dtype-backed :class:`DataFrame`\u001b[39m\n",
       "\u001b[33m        * ``\"pyarrow\"``: returns pyarrow-backed nullable\u001b[39m\n",
       "\u001b[33m          :class:`ArrowDtype` :class:`DataFrame`\u001b[39m\n",
       "\n",
       "\u001b[33m        .. versionadded:: 2.0\u001b[39m\n",
       "\n",
       "\u001b[33m    storage_options : dict, optional\u001b[39m\n",
       "\u001b[33m        Extra options that make sense for a particular storage connection, e.g.\u001b[39m\n",
       "\u001b[33m        host, port, username, password, etc. For HTTP(S) URLs the key-value pairs\u001b[39m\n",
       "\u001b[33m        are forwarded to ``urllib.request.Request`` as header options. For other\u001b[39m\n",
       "\u001b[33m        URLs (e.g. starting with \"s3://\", and \"gcs://\") the key-value pairs are\u001b[39m\n",
       "\u001b[33m        forwarded to ``fsspec.open``. Please see ``fsspec`` and ``urllib`` for more\u001b[39m\n",
       "\u001b[33m        details, and for more examples on storage options refer `here\u001b[39m\n",
       "\u001b[33m        <https://pandas.pydata.org/docs/user_guide/io.html?\u001b[39m\n",
       "\u001b[33m        highlight=storage_options#reading-writing-remote-files>`_.\u001b[39m\n",
       "\n",
       "\u001b[33m        .. versionadded:: 2.1.0\u001b[39m\n",
       "\n",
       "\u001b[33m    Returns\u001b[39m\n",
       "\u001b[33m    -------\u001b[39m\n",
       "\u001b[33m    dfs\u001b[39m\n",
       "\u001b[33m        A list of DataFrames.\u001b[39m\n",
       "\n",
       "\u001b[33m    See Also\u001b[39m\n",
       "\u001b[33m    --------\u001b[39m\n",
       "\u001b[33m    read_csv : Read a comma-separated values (csv) file into DataFrame.\u001b[39m\n",
       "\n",
       "\u001b[33m    Notes\u001b[39m\n",
       "\u001b[33m    -----\u001b[39m\n",
       "\u001b[33m    Before using this function you should read the :ref:`gotchas about the\u001b[39m\n",
       "\u001b[33m    HTML parsing libraries <io.html.gotchas>`.\u001b[39m\n",
       "\n",
       "\u001b[33m    Expect to do some cleanup after you call this function. For example, you\u001b[39m\n",
       "\u001b[33m    might need to manually assign column names if the column names are\u001b[39m\n",
       "\u001b[33m    converted to NaN when you pass the `header=0` argument. We try to assume as\u001b[39m\n",
       "\u001b[33m    little as possible about the structure of the table and push the\u001b[39m\n",
       "\u001b[33m    idiosyncrasies of the HTML contained in the table to the user.\u001b[39m\n",
       "\n",
       "\u001b[33m    This function searches for ``<table>`` elements and only for ``<tr>``\u001b[39m\n",
       "\u001b[33m    and ``<th>`` rows and ``<td>`` elements within each ``<tr>`` or ``<th>``\u001b[39m\n",
       "\u001b[33m    element in the table. ``<td>`` stands for \"table data\". This function\u001b[39m\n",
       "\u001b[33m    attempts to properly handle ``colspan`` and ``rowspan`` attributes.\u001b[39m\n",
       "\u001b[33m    If the function has a ``<thead>`` argument, it is used to construct\u001b[39m\n",
       "\u001b[33m    the header, otherwise the function attempts to find the header within\u001b[39m\n",
       "\u001b[33m    the body (by putting rows with only ``<th>`` elements into the header).\u001b[39m\n",
       "\n",
       "\u001b[33m    Similar to :func:`~read_csv` the `header` argument is applied\u001b[39m\n",
       "\u001b[33m    **after** `skiprows` is applied.\u001b[39m\n",
       "\n",
       "\u001b[33m    This function will *always* return a list of :class:`DataFrame` *or*\u001b[39m\n",
       "\u001b[33m    it will fail, i.e., it will *not* return an empty list, save for some\u001b[39m\n",
       "\u001b[33m    rare cases.\u001b[39m\n",
       "\u001b[33m    It might return an empty list in case of inputs with single row and\u001b[39m\n",
       "\u001b[33m    ``<td>`` containing only whitespaces.\u001b[39m\n",
       "\n",
       "\u001b[33m    Examples\u001b[39m\n",
       "\u001b[33m    --------\u001b[39m\n",
       "\u001b[33m    See the :ref:`read_html documentation in the IO section of the docs\u001b[39m\n",
       "\u001b[33m    <io.read_html>` for some examples of reading in HTML tables.\u001b[39m\n",
       "\u001b[33m    \"\"\"\u001b[39m\n",
       "    \u001b[38;5;66;03m# Type check here. We don't want to parse only to fail because of an\u001b[39;00m\n",
       "    \u001b[38;5;66;03m# invalid value of an integer skiprows.\u001b[39;00m\n",
       "    \u001b[38;5;28;01mif\u001b[39;00m isinstance(skiprows, numbers.Integral) \u001b[38;5;28;01mand\u001b[39;00m skiprows < \u001b[32m0\u001b[39m:\n",
       "        \u001b[38;5;28;01mraise\u001b[39;00m ValueError(\n",
       "            \u001b[33m\"cannot skip rows starting from the end of the \"\u001b[39m\n",
       "            \u001b[33m\"data (you passed a negative value)\"\u001b[39m\n",
       "        )\n",
       "    \u001b[38;5;28;01mif\u001b[39;00m extract_links \u001b[38;5;28;01mnot\u001b[39;00m \u001b[38;5;28;01min\u001b[39;00m [\u001b[38;5;28;01mNone\u001b[39;00m, \u001b[33m\"header\"\u001b[39m, \u001b[33m\"footer\"\u001b[39m, \u001b[33m\"body\"\u001b[39m, \u001b[33m\"all\"\u001b[39m]:\n",
       "        \u001b[38;5;28;01mraise\u001b[39;00m ValueError(\n",
       "            \u001b[33m\"`extract_links` must be one of \"\u001b[39m\n",
       "            \u001b[33m'{None, \"header\", \"footer\", \"body\", \"all\"}, got '\u001b[39m\n",
       "            f'\"{extract_links}\"'\n",
       "        )\n",
       "\n",
       "    validate_header_arg(header)\n",
       "    check_dtype_backend(dtype_backend)\n",
       "\n",
       "    io = stringify_path(io)\n",
       "\n",
